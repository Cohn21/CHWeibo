<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.WeiboClient" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/weibo_orange</item>
        <item name="colorPrimaryDark">@color/weibo_orange_dark</item>
        <item name="colorAccent">@color/weibo_orange</item>
        <item name="android:statusBarColor">@color/weibo_orange</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.WeiboClient.Splash" parent="Theme.WeiboClient">
        <item name="android:windowBackground">@color/weibo_orange</item>
    </style>
</resources>
